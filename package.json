{
	"name": "portfolio",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^6",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.6",
			"react-dom": "^19.2.6",
			"sonner": "^2.0.5",
			"@types/react": "^19.2.15",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.1.18"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@portfolio/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@portfolio/config": "workspace:*",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"turbo": "^2.9.16",
		"typescript": "catalog:"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "bun@1.3.5"
}
